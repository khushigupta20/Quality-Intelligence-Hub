# Optional: override the default port (default: 5000)
PORT=5000

# ── IBM watsonx.ai (required for AI-enhanced Defect RCA) ──────────────────────
# These can be set here as environment variables, or entered via the Settings UI
# (which stores them in config.json).
#
# Get your API key    : https://cloud.ibm.com/iam/apikeys → Create an IBM Cloud API key
# Get your Project ID : https://dataplatform.cloud.ibm.com/projects/ → open project → Manage tab
WATSONX_API_KEY=your-iam-api-key-here
WATSONX_PROJECT_ID=your-watsonx-project-id-here

# Optional overrides
# WATSONX_MODEL_ID=ibm/granite-3-8b-instruct
# WATSONX_EMBED_MODEL=ibm/slate-125m-english-rtrvr
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
